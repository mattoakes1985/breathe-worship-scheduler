# Breathe Worship Scheduler — required environment variables (PRD §9.4)
# Copy to .env.local for local dev. NEVER commit real values.

# Supabase project (frontend-safe values: URL + publishable/anon key only.
# The service-role key must never appear in frontend env.)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Resend (used by the notification Edge Function only — set via
# `supabase secrets set RESEND_API_KEY=...`, not in frontend env)
# RESEND_API_KEY=re_xxxxxxxxxxxx
